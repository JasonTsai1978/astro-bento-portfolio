---
import Card from "./Card/index.astro";
---
<script>
  let interval: ReturnType<typeof setInterval>;

  function updateClock() {
    const timeDisplay = document.getElementById("timeDisplay");
    const now = new Date();
    if (timeDisplay) {
      const formatted = now.toLocaleTimeString("en-US", {
        timeZone: "Asia/Taipei",
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
      });
      timeDisplay.textContent = formatted + " TST";
      timeDisplay.setAttribute("datetime", now.toISOString());
    }
  }

  updateClock();
  interval = setInterval(updateClock, 1000);
</script>

<Card colSpan="md:col-span-1" rowSpan="md:row-span-1" title="Time zone">
  <time
    class="text-2xl xl:text-5xl xl:whitespace-nowrap w-50 xl:w-100 h-[calc(100%-28px)] font-serif flex justify-center items-center"
    datetime=""
    id="timeDisplay"
  >
  </time>
</Card>
