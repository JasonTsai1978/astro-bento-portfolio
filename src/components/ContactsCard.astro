---
import Card from "./Card/index.astro";
import { LINKS } from "../lib/constants";
---
<Card colSpan="md:col-span-1" rowSpan="md:row-span-4">
  <div class="h-full">
    <header class="flex items-center">
      <h1 class="text-white text-xl font-bold">
        Let's connect.
      </h1>
    </header>
    <address class="flex flex-col mt-4 not-italic">
      <h2 class="text-gray-500">Location</h2>
      <p>Hsinchu, Taiwan</p>
    </address>
    <div class="flex flex-col mt-4 w-fit">
      <h2 class="text-gray-500">Socials</h2>
      <ul class="flex flex-col gap-1">
        <li>
          <a href={LINKS.linkedin} target="_blank" class="hover:text-white transition-colors">LinkedIn</a>
        </li>
        <li>
          <a href={LINKS.github} target="_blank" class="hover:text-white transition-colors">GitHub</a>
        </li>
        <li>
          <a href={`mailto:${LINKS.email}`} class="hover:text-white transition-colors">Email</a>
        </li>
      </ul>
    </div>
    <div class="flex flex-col mt-4">
      <h2 class="text-gray-500">Currently open to</h2>
      <ul class="flex flex-col gap-1 text-sm font-light">
        <li>💬 Industry conversations</li>
        <li>🤝 AI & automation collaboration</li>
        <li>📩 Speaking & advisory</li>
      </ul>
    </div>
  </div>
</Card>
